  <script>
    let currentRate = 'all';

    function switchArea(area) {
      const targetTab = document.getElementById('tab-' + area);
      const isAlreadyActive = targetTab && targetTab.classList.contains('tab-active');
      // clear all active states
      document.querySelectorAll('.area-section').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('[id^="tab-"]').forEach(el => {
        el.classList.remove('tab-active');
        el.classList.add('tab-inactive');
      });
      if (isAlreadyActive) {
        // toggle off: show all
        document.body.classList.remove('area-filtered');
        applyFilterAll();
        return;
      }
      // toggle on: filter to selected
      document.body.classList.add('area-filtered');
      const sec = document.getElementById('area-' + area);
      if (sec) sec.classList.add('active');
      if (targetTab) {
        targetTab.classList.add('tab-active');
        targetTab.classList.remove('tab-inactive');
      }
      applyFilter();
    }

    function applyFilterAll() {
      // when no tab is active, apply filter across all visible sections
      const sections = document.querySelectorAll('.area-section');
      let total = 0;
      sections.forEach(sec => {
        const cards = sec.querySelectorAll('.store-card');
        cards.forEach(card => {
          const show = currentRate === 'all' || card.dataset.rate === currentRate;
          card.style.display = show ? '' : 'none';
          if (show) total++;
        });
      });
      const countEl = document.getElementById('filter-count');
      if (countEl) countEl.textContent = currentRate !== 'all' ? total + '件表示' : '';
    }

    function setFilter(rate) {
      currentRate = rate;
      document.querySelectorAll('.rate-btn').forEach(btn => {
        const active = btn.dataset.rate === rate;
        btn.classList.toggle('tab-active', active);
        btn.classList.toggle('tab-inactive', !active);
      });
      applyFilter();
    }

    function applyFilter() {
      if (!document.body.classList.contains('area-filtered')) {
        applyFilterAll();
        return;
      }
      const section = document.querySelector('.area-section.active');
      if (!section) return;
      const cards = section.querySelectorAll('.store-card');
      let visible = 0;
      cards.forEach(card => {
        const show = currentRate === 'all' || card.dataset.rate === currentRate;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      const countEl = document.getElementById('filter-count');
      if (countEl) countEl.textContent = currentRate !== 'all' ? visible + '件表示' : '';
    }
  </script>

