  <script>
    function mapJumpTab(tabId) {
      switchArea(tabId);
      setTimeout(function() {
        var el = document.getElementById('area-' + tabId);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
    }
    document.querySelectorAll('.map-pin').forEach(function(p) {
      p.addEventListener('click', function() {
        mapJumpTab(p.dataset.tab);
      });
      p.addEventListener('mouseenter', function() {
        var c = p.querySelector('circle');
        if (c) { c.setAttribute('r', '9'); }
      });
      p.addEventListener('mouseleave', function() {
        var c = p.querySelector('circle');
        if (c) { c.setAttribute('r', '6'); }
      });
    });
  </script>

