      <text x="340" y="81" text-anchor="middle" fill="#fff" font-size="10" font-weight="700" style="paint-order:stroke;stroke:#0d0d0d;stroke-width:2.5;stroke-linejoin:round" class="pointer-events-none select-none">蕨</text>
